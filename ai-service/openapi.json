    "/llm/portfolio-eval": {
      "post": {
        "tags": [
          "Portfolio"
        ],
        "summary": "Evaluate expert portfolio submission for seam-boundary competency",
        "description": "Called by NestJS PortfolioService after an expert submits a portfolio entry.\n\nFlow (NestJS side):\n  1. Increment expert_seam_claims.submission_count\n  2. Call this endpoint\n  3. If passed_boolean = True → update verification_tier to EVIDENCE_BACKED\n  4. If passed_boolean = False → increment failure count, check lockout threshold\n  5. Write platform_decisions row with confidence + gap_advisory\n\nReturns:\n    PortfolioEvalResponse — confidence_score, passed_boolean, gap_advisory",
        "operationId": "portfolio_eval_llm_portfolio_eval_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PortfolioEvalRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PortfolioEvalResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/llm/matching": {
      "post": {
        "tags": [
          "Matching"
        ],
        "summary": "Score and rank expert profiles against project requirements",
        "description": "Called by NestJS ProjectsService when a CEO project is published.\n\nScores each expert in expert_profiles using a 5-dimension composite:\n  40% seam coverage (weighted by criticality)\n  25% domain depth match\n  20% portfolio evaluation quality\n  10% archetype history match\n   5% engagement model compat (always 1.0 — NestJS pre-filters)\n\nReturns experts sorted by composite_score descending.\nNestJS displays the top N results in the CEO shortlist view.\n\nReturns an empty list (not an error) if no experts were provided.",
        "operationId": "match_experts_llm_matching_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MatchingRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/MatchResult"
                  },
                  "type": "array",
                  "title": "Response Match Experts Llm Matching Post"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/llm/dispute-eval": {
      "post": {
        "tags": [
          "Disputes"
        ],
        "summary": "Neutral arbitration — evaluate deliverable against acceptance criterion",
        "description": "Called by NestJS DisputeService immediately after a dispute is filed.\n\nFlow (NestJS side):\n  1. Create dispute row (state = LAYER_1_EVAL)\n  2. Call this endpoint\n  3. Write llm_confidence to dispute row\n  4. If confidence_score >= 0.80:\n        state = AUTO_RESOLVED\n        call LedgerService.resolveDispute() with finding-based resolution\n     else:\n        state = MANUAL_REVIEW\n        admin sees it in the Dispute Monitor dashboard\n\nReturns:\n    DisputeEvalResponse — confidence_score, finding (\"expert_wins\"|\"client_wins\")",
        "operationId": "dispute_eval_llm_dispute_eval_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DisputeEvalRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DisputeEvalResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
