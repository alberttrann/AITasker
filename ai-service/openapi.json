    "/llm/service-generate": {
      "post": {
        "tags": [
          "Service Generator"
        ],
        "summary": "Generate a structured AI consulting service listing draft",
        "description": "Called by NestJS ListingsService when an expert uses the AI-assist feature.\n\nFlow (NestJS side):\n  1. Expert clicks 'Generate with AI' on the service creation form\n  2. Frontend sends expert's capabilities + intended use cases to NestJS\n  3. NestJS calls this endpoint\n  4. Draft is pre-filled into the form; expert edits and publishes\n\nThe generated draft is not persisted directly — the expert always reviews.\nsuggested_price_vnd=0 means the LLM could not estimate from the scope given.",
        "operationId": "service_generate_llm_service_generate_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
