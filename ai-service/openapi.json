    "/projects/{project_id}/artifact-b": {
      "get": {
        "tags": [
          "Artifact B"
        ],
        "summary": "Gate check — can this expert access the technical specification?",
        "description": "Called by NestJS ProjectsService before returning artifact_b_json to an expert.\n\nNestJS flow:\n  1. Expert calls GET /projects/{id} (NestJS endpoint)\n  2. NestJS fetches engagement + bid state from DB\n  3. NestJS calls this endpoint with context\n  4. If 200: NestJS includes artifact_b_json in the response\n  5. If 403: NestJS returns project without artifact_b_json\n\nAll 4 conditions must be true simultaneously.\nThe first failing condition is returned as the denial reason.",
        "operationId": "artifact_b_gate_projects__project_id__artifact_b_get",
        "parameters": [
          {
            "name": "project_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Project Id"
            }
          },
          {
            "name": "engagement_state",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "description": "Current engagement state",
              "title": "Engagement State"
            },
            "description": "Current engagement state"
          },
          {
            "name": "bid_state",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "description": "Current bid state",
              "title": "Bid State"
            },
            "description": "Current bid state"
          },
          {
            "name": "expert_nda_accepted",
            "in": "query",
            "required": true,
            "schema": {
              "type": "boolean",
              "description": "Has expert accepted NDA?",
              "title": "Expert Nda Accepted"
            },
            "description": "Has expert accepted NDA?"
          },
          {
            "name": "ceo_nda_accepted",
            "in": "query",
            "required": true,
            "schema": {
              "type": "boolean",
              "description": "Has CEO accepted NDA?",
              "title": "Ceo Nda Accepted"
            },
            "description": "Has CEO accepted NDA?"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
