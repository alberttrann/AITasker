# LLM — Google Gemini (via google-genai SDK) 
# Get free key at: https://aistudio.google.com/app/apikey
# Variable kept as ANTHROPIC_API_KEY so team .env files need no changes.
ANTHROPIC_API_KEY=YOUR_GEMINI_API_KEY_FROM_AISTUDIO

# Model to use (default: gemini-2.5-flash)
LLM_MODEL=gemini-2.5-flash

# Temperature: 0.0 = deterministic, 1.0 = creative
# Keep low (0.1) for structured JSON outputs
LLM_TEMPERATURE=0.1

# Max tokens in LLM output (8192 covers all endpoints including stage5-synthesize)
LLM_MAX_OUTPUT_TOKENS=8192

# Confidence thresholds
# BR-VER-03: portfolio evaluation pass threshold
PORTFOLIO_EVAL_THRESHOLD=0.85

# BR-DIS-05: dispute auto-resolution threshold (NestJS reads this from ai-service response)
DISPUTE_EVAL_THRESHOLD=0.80

# Service
PORT=8000
ENV=development
