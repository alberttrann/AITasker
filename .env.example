DATABASE_URL=""

DIRECT_URL=""


PLATFORM_SETTINGS_ID=00000000-0000-0000-0000-000000000004


JWT_SECRET=REPLACE_WITH_64_BYTE_HEX_STRING
JWT_EXPIRES_IN=7d


SEPAY_SECRET_KEY=REPLACE_WITH_SEPAY_HMAC_SECRET
SEPAY_API_BASE=https://my.sepay.vn/userapi
FASTAPI_URL=http://localhost:8000

PORT=3000
NODE_ENV=development

# Dev only 
# Plain-text admin password for local dev — rotate trước deploy
SEED_ADMIN_PASSWORD=Admin@AITasker2024!

# OpenWiki docs generation (OpenAI-compatible provider)
# GitHub Actions uses repo secrets OPENAI_COMPATIBLE_API_KEY,
# OPENAI_COMPATIBLE_BASE_URL, and OPENAI_COMPATIBLE_MODEL_ID.
# In CI, OPENAI_COMPATIBLE_MODEL_ID is mapped to OPENWIKI_MODEL_ID.
#
# DeepSeek example via OpenAI-compatible endpoint:
# OPENWIKI_PROVIDER=openai-compatible
# OPENAI_COMPATIBLE_API_KEY=your-deepseek-api-key
# OPENAI_COMPATIBLE_BASE_URL=https://api.deepseek.com/v1
# OPENWIKI_MODEL_ID=deepseek-v4-pro
# Use whatever model id your provider/gateway exposes, e.g. deepseek-v4-pro
# or deepseek-v4-pro if your gateway uses that name.
OPENWIKI_PROVIDER=openai-compatible
OPENAI_COMPATIBLE_API_KEY=Key cua may
OPENAI_COMPATIBLE_BASE_URL=https://your-openai-compatible-provider.example.com/v1
OPENWIKI_MODEL_ID=your-openai-compatible-model-id
