generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                                       String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                                    String                @unique
  passwordHash                             String                @map("password_hash")
  fullName                                 String                @map("full_name")
  phone                                    String?
  roles                                    Json                  @default("[]")
  activeRole                               String                @default("CLIENT") @map("active_role")
  clientSubtype                            String?               @map("client_subtype")
  subscriptionClientTier                   String                @default("free") @map("subscription_client_tier")
  subscriptionExpertTier                   String                @default("free") @map("subscription_expert_tier")
  subClientExpiresAt                       DateTime?             @map("sub_client_expires_at") @db.Timestamptz(6)
  subExpertExpiresAt                       DateTime?             @map("sub_expert_expires_at") @db.Timestamptz(6)
  sepayBankAccountXid                      String?               @map("sepay_bank_account_xid")
  bankAccountHolderName                    String?               @map("bank_account_holder_name")
  bankLinkedAt                             DateTime?             @map("bank_linked_at") @db.Timestamptz(6)
  selfTechnical                            Boolean               @default(false) @map("self_technical")
  isActive                                 Boolean               @default(true) @map("is_active")
  createdAt                                DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  self_technical_projects                  Json                  @default("[]")
  clientProfile                            ClientProfile?
  disputesFiled                            Dispute[]
  elicitationSessions                      ElicitationSession[]
  engagements_engagements_client_idTousers Engagement[]          @relation("engagements_client_idTousers")
  expertEngagements                        Engagement[]          @relation("ExpertEngagements")
  expertDomainDepths                       ExpertDomainDepth[]
  expertProfile                            ExpertProfile?
  expertSeamClaims                         ExpertSeamClaim[]
  messageReads                             MessageRead[]
  sentMessages                             Message[]
  milestonesSubmitted                      MilestoneSubmission[]
  portfolioSubmissions                     PortfolioSubmission[]
  clientProjects                           Project[]             @relation("ClientProjects")
  reviewsWritten                           Review[]              @relation("ReviewsWritten")
  reviewsReceived                          Review[]              @relation("ReviewsReceived")
  expertServices                           Service[]
  linkedTechTeams                          TechTeamProfile[]     @relation("LinkedClient")
  techTeamProfile                          TechTeamProfile?
  wallet                                   Wallet?
  withdrawalRequests                       WithdrawalRequest[]

  @@index([activeRole])
  @@map("users")
}

model ClientProfile {
  userId      String  @id @map("user_id") @db.Uuid
  companyName String? @map("company_name")
  industry    String?
  ceoName     String? @map("ceo_name")
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("client_profiles")
}

model ExpertProfile {
  userId               String  @id @map("user_id") @db.Uuid
  bio                  String?
  engagementModel      String? @map("engagement_model")
  stackTagsJson        Json    @default("[]") @map("stack_tags_json")
  archetypeHistoryJson Json    @default("[]") @map("archetype_history_json")
  user                 User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("expert_profiles")
}

model TechTeamProfile {
  userId          String   @id @map("user_id") @db.Uuid
  linkedClientId  String   @map("linked_client_id") @db.Uuid
  linkedProjectId String?  @map("linked_project_id") @db.Uuid
  roleTitle       String?  @map("role_title")
  linkedClient    User     @relation("LinkedClient", fields: [linkedClientId], references: [id])
  linkedProject   Project? @relation(fields: [linkedProjectId], references: [id])
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([linkedProjectId])
  @@map("tech_team_profiles")
}

model Wallet {
  id               String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String              @unique @map("user_id") @db.Uuid
  availableBalance BigInt              @default(0) @map("available_balance")
  lockedBalance    BigInt              @default(0) @map("locked_balance")
  escrowsAsClient  EscrowAccount[]     @relation("ClientWallet")
  escrowsAsExpert  EscrowAccount[]     @relation("ExpertWallet")
  platformSettings PlatformSettings?
  transactions     WalletTransaction[]
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("wallets")
}

model WalletTransaction {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  walletId        String   @map("wallet_id") @db.Uuid
  amount          BigInt
  transactionType String   @map("transaction_type")
  referenceId     String?  @map("reference_id")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  wallet          Wallet   @relation(fields: [walletId], references: [id])

  @@index([walletId])
  @@index([transactionType])
  @@index([createdAt(sort: Desc)])
  @@map("wallet_transactions")
}

model VirtualAccount {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entityType  String    @map("entity_type")
  entityId    String    @map("entity_id")
  vaNumber    String    @unique @map("va_number")
  fixedAmount BigInt?   @map("fixed_amount")
  expiresAt   DateTime? @map("expires_at") @db.Timestamptz(6)
  status      String    @default("ACTIVE")

  @@index([entityType, entityId])
  @@index([status])
  @@map("virtual_accounts")
}

model WithdrawalRequest {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  expertId       String    @map("expert_id") @db.Uuid
  type           String
  amount         BigInt
  bankAccountXid String    @map("bank_account_xid")
  disbursementId String?   @map("disbursement_id")
  status         String    @default("PENDING")
  requestedAt    DateTime  @default(now()) @map("requested_at") @db.Timestamptz(6)
  confirmedAt    DateTime? @map("confirmed_at") @db.Timestamptz(6)
  expert         User      @relation(fields: [expertId], references: [id])

  @@index([expertId])
  @@index([status])
  @@map("withdrawal_requests")
}

model PlatformSettings {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  platformWalletId String?  @unique @map("platform_wallet_id") @db.Uuid
  platformFeePct   Float    @default(0.05) @map("platform_fee_pct")
  updatedAt        DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  platformWallet   Wallet?  @relation(fields: [platformWalletId], references: [id])

  @@map("platform_settings")
}

model ElicitationSession {
  id                          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                      String    @map("user_id") @db.Uuid
  currentStage                Int       @default(1) @map("current_stage")
  archetype                   String?
  scenarioType                String?   @map("scenario_type")
  voidListJson                Json      @default("[]") @map("void_list_json")
  state                       String    @default("IN_PROGRESS")
  createdAt                   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  stage1SymptomsJson          Json?     @map("stage1_symptoms_json")
  stage3ProbesJson            Json?     @map("stage3_probes_json")
  stage4TechInputsJson        Json?     @map("stage4_tech_inputs_json")
  handoff_token_jti           String?
  handoff_consumed_at         DateTime? @db.Timestamptz(6)
  recommended_archetypes_json Json?
  user                        User      @relation(fields: [userId], references: [id])
  project                     Project?

  @@index([userId])
  @@index([state])
  @@map("elicitation_sessions")
}

model Project {
  id                     String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId               String              @map("client_id") @db.Uuid
  elicitationSessionId   String?             @unique @map("elicitation_session_id") @db.Uuid
  state                  String              @default("PUBLISHED")
  archetype              String?
  tier                   String?
  selfTechnical          Boolean             @default(false) @map("self_technical")
  requiredSeamsJson      Json                @default("[]") @map("required_seams_json")
  requiredDomainsJson    Json                @default("[]") @map("required_domains_json")
  milestoneFrameworkJson Json                @default("[]") @map("milestone_framework_json")
  artifactAJson          Json?               @map("artifact_a_json")
  artifactBJson          Json?               @map("artifact_b_json")
  createdAt              DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  engagements            Engagement[]
  client                 User                @relation("ClientProjects", fields: [clientId], references: [id])
  elicitationSession     ElicitationSession? @relation(fields: [elicitationSessionId], references: [id])
  techTeamProfiles       TechTeamProfile[]

  @@index([clientId])
  @@index([state])
  @@map("projects")
}

model ExpertDomainDepth {
  id               String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  expertId         String @map("expert_id") @db.Uuid
  domainCode       String @map("domain_code")
  depthLevel       String @map("depth_level")
  verificationTier String @default("CLAIMED") @map("verification_tier")
  expert           User   @relation(fields: [expertId], references: [id], onDelete: Cascade)

  @@unique([expertId, domainCode])
  @@index([expertId])
  @@map("expert_domain_depths")
}

model ExpertSeamClaim {
  id                   String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  expertId             String                @map("expert_id") @db.Uuid
  seamCode             String                @map("seam_code")
  verificationTier     String                @default("CLAIMED") @map("verification_tier")
  submissionCount      Int                   @default(0) @map("submission_count")
  lockedUntil          DateTime?             @map("locked_until") @db.Timestamptz(6)
  expert               User                  @relation(fields: [expertId], references: [id], onDelete: Cascade)
  portfolioSubmissions PortfolioSubmission[]

  @@unique([expertId, seamCode])
  @@index([expertId])
  @@map("expert_seam_claims")
}

model PortfolioSubmission {
  id                 String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  expertId           String          @map("expert_id") @db.Uuid
  seamClaimId        String          @map("seam_claim_id") @db.Uuid
  projectDescription String          @map("project_description")
  decisionPoints     String          @map("decision_points")
  status             String          @default("PENDING")
  llmConfidence      Float?          @map("llm_confidence")
  submittedAt        DateTime        @default(now()) @map("submitted_at") @db.Timestamptz(6)
  evaluatedAt        DateTime?       @map("evaluated_at") @db.Timestamptz(6)
  expert             User            @relation(fields: [expertId], references: [id])
  seamClaim          ExpertSeamClaim @relation(fields: [seamClaimId], references: [id])

  @@index([expertId])
  @@index([seamClaimId])
  @@map("portfolio_submissions")
}

model Service {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  expertId    String       @map("expert_id") @db.Uuid
  title       String
  description String?
  domainsJson Json         @default("[]") @map("domains_json")
  seamsJson   Json         @default("[]") @map("seams_json")
  priceVnd    BigInt       @map("price_vnd")
  state       String       @default("DRAFT")
  serviceType String       @map("service_type")
  engagements Engagement[]
  expert      User         @relation(fields: [expertId], references: [id])

  @@index([expertId])
  @@index([state])
  @@index([serviceType])
  @@map("services")
}

model Engagement {
  id                                 String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId                          String?         @map("project_id") @db.Uuid
  expertId                           String          @map("expert_id") @db.Uuid
  client_id                          String          @db.Uuid
  serviceId                          String?         @map("service_id") @db.Uuid
  type                               String
  state                              String          @default("PENDING")
  connectedAt                        DateTime?       @map("connected_at") @db.Timestamptz(6)
  clientNdaAcceptedAt                DateTime?       @map("client_nda_accepted_at") @db.Timestamptz(6)
  expertNdaAcceptedAt                DateTime?       @map("expert_nda_accepted_at") @db.Timestamptz(6)
  capabilityBid                      CapabilityBid?
  disputes                           Dispute[]
  users_engagements_client_idTousers User            @relation("engagements_client_idTousers", fields: [client_id], references: [id])
  expert                             User            @relation("ExpertEngagements", fields: [expertId], references: [id])
  project                            Project?        @relation(fields: [projectId], references: [id])
  service                            Service?        @relation(fields: [serviceId], references: [id])
  escrowAccounts                     EscrowAccount[] @relation("EngagementEscrow")
  messages                           Message[]
  milestones                         Milestone[]
  reviews                            Review[]

  @@index([projectId])
  @@index([expertId])
  @@index([serviceId])
  @@index([state])
  @@index([client_id])
  @@map("engagements")
}

model CapabilityBid {
  id                     String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  engagementId           String     @unique @map("engagement_id") @db.Uuid
  footprintAlignmentJson Json?      @map("footprint_alignment_json")
  approachSummary        String?    @map("approach_summary")
  conditionalPricingJson Json?      @map("conditional_pricing_json")
  state                  String     @default("DRAFT")
  techStatus             String     @default("PENDING") @map("tech_status")
  ceoStatus              String     @default("PENDING") @map("ceo_status")
  techFeedback           String?    @map("tech_feedback")
  negotiatedPriceVnd     BigInt?    @map("negotiated_price_vnd")
  versionNumber          Int        @default(1) @map("version_number")
  engagement             Engagement @relation(fields: [engagementId], references: [id])

  @@index([techStatus])
  @@index([ceoStatus])
  @@map("capability_bids")
}

model Milestone {
  id                   String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  engagementId         String                @map("engagement_id") @db.Uuid
  milestoneNumber      Int                   @map("milestone_number")
  deliverableStatement String?               @map("deliverable_statement")
  signOffAuthority     String                @map("sign_off_authority")
  paymentAmountVnd     BigInt                @map("payment_amount_vnd")
  state                String                @default("DEFINED")
  vaNumber             String?               @map("va_number")
  vaExpiresAt          DateTime?             @map("va_expires_at") @db.Timestamptz(6)
  fundedAt             DateTime?             @map("funded_at") @db.Timestamptz(6)
  submittedAt          DateTime?             @map("submitted_at") @db.Timestamptz(6)
  approvedAt           DateTime?             @map("approved_at") @db.Timestamptz(6)
  releasedAt           DateTime?             @map("released_at") @db.Timestamptz(6)
  acceptanceCriteria   AcceptanceCriterion[]
  disputes             Dispute[]
  escrowAccounts       EscrowAccount[]       @relation("MilestoneEscrow")
  dodItems             MilestoneDodItem[]
  submissions          MilestoneSubmission[]
  engagement           Engagement            @relation(fields: [engagementId], references: [id])
  paygatedDocuments    PaygatedDocument[]

  @@unique([engagementId, milestoneNumber])
  @@index([engagementId])
  @@index([state])
  @@map("milestones")
}

model AcceptanceCriterion {
  id             String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  milestoneId    String             @map("milestone_id") @db.Uuid
  criterionText  String             @map("criterion_text")
  isRequired     Boolean            @default(true) @map("is_required")
  verifiedByRole String             @map("verified_by_role")
  verifiedAt     DateTime?          @map("verified_at") @db.Timestamptz(6)
  revisionNote   String?            @map("revision_note")
  milestone      Milestone          @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  disputes       Dispute[]
  dodItems       MilestoneDodItem[]

  @@index([milestoneId])
  @@map("acceptance_criteria")
}

model MilestoneDodItem {
  id                String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  milestoneId       String               @map("milestone_id") @db.Uuid
  itemDescription   String               @map("item_description")
  isRequired        Boolean              @default(true) @map("is_required")
  status            String               @default("PENDING")
  completedAt       DateTime?            @map("completed_at") @db.Timestamptz(6)
  completionNote    String?              @map("completion_note")
  notApplicableNote String?              @map("not_applicable_note")
  mapsToCriterionId String?              @map("maps_to_criterion_id") @db.Uuid
  criterion         AcceptanceCriterion? @relation(fields: [mapsToCriterionId], references: [id])
  milestone         Milestone            @relation(fields: [milestoneId], references: [id], onDelete: Cascade)

  @@index([milestoneId])
  @@map("milestone_dod_items")
}

model MilestoneSubmission {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  milestoneId String    @map("milestone_id") @db.Uuid
  expertId    String    @map("expert_id") @db.Uuid
  description String?
  filesJson   Json      @default("[]") @map("files_json")
  submittedAt DateTime  @default(now()) @map("submitted_at") @db.Timestamptz(6)
  expert      User      @relation(fields: [expertId], references: [id])
  milestone   Milestone @relation(fields: [milestoneId], references: [id])

  @@index([milestoneId])
  @@index([expertId])
  @@map("milestone_submissions")
}

model PaygatedDocument {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  milestoneId  String    @map("milestone_id") @db.Uuid
  documentUrl  String    @map("document_url")
  releaseState String    @default("STAGED") @map("release_state")
  stagedAt     DateTime  @default(now()) @map("staged_at") @db.Timestamptz(6)
  releasedAt   DateTime? @map("released_at") @db.Timestamptz(6)
  milestone    Milestone @relation(fields: [milestoneId], references: [id])

  @@index([milestoneId])
  @@index([milestoneId, releaseState])
  @@map("paygated_documents")
}

model EscrowAccount {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  milestoneId    String?     @map("milestone_id") @db.Uuid
  engagementId   String?     @map("engagement_id") @db.Uuid
  amount         BigInt
  clientWalletId String      @map("client_wallet_id") @db.Uuid
  expertWalletId String      @map("expert_wallet_id") @db.Uuid
  status         String      @default("HELD")
  heldAt         DateTime    @default(now()) @map("held_at") @db.Timestamptz(6)
  releasedAt     DateTime?   @map("released_at") @db.Timestamptz(6)
  disputes       Dispute[]
  clientWallet   Wallet      @relation("ClientWallet", fields: [clientWalletId], references: [id])
  engagement     Engagement? @relation("EngagementEscrow", fields: [engagementId], references: [id])
  expertWallet   Wallet      @relation("ExpertWallet", fields: [expertWalletId], references: [id])
  milestone      Milestone?  @relation("MilestoneEscrow", fields: [milestoneId], references: [id])

  @@index([status])
  @@index([clientWalletId])
  @@index([expertWalletId])
  @@map("escrow_accounts")
}

model Dispute {
  id              String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  engagementId    String              @map("engagement_id") @db.Uuid
  milestoneId     String?             @map("milestone_id") @db.Uuid
  criterionId     String              @map("criterion_id") @db.Uuid
  escrowAccountId String              @map("escrow_account_id") @db.Uuid
  filedBy         String              @map("filed_by") @db.Uuid
  state           String              @default("PENDING")
  llmConfidence   Float?              @map("llm_confidence")
  filedAt         DateTime            @default(now()) @map("filed_at") @db.Timestamptz(6)
  resolvedAt      DateTime?           @map("resolved_at") @db.Timestamptz(6)
  criterion       AcceptanceCriterion @relation(fields: [criterionId], references: [id])
  engagement      Engagement          @relation(fields: [engagementId], references: [id])
  escrowAccount   EscrowAccount       @relation(fields: [escrowAccountId], references: [id])
  filer           User                @relation(fields: [filedBy], references: [id])
  milestone       Milestone?          @relation(fields: [milestoneId], references: [id])

  @@index([engagementId])
  @@index([state])
  @@index([escrowAccountId])
  @@map("disputes")
}

model Message {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  engagementId  String        @map("engagement_id") @db.Uuid
  senderId      String        @map("sender_id") @db.Uuid
  content       String
  attachmentUrl String?       @map("attachment_url")
  timestamp     DateTime      @default(now()) @db.Timestamptz(6)
  reads         MessageRead[]
  engagement    Engagement    @relation(fields: [engagementId], references: [id])
  sender        User          @relation(fields: [senderId], references: [id])

  @@index([engagementId, timestamp])
  @@index([senderId])
  @@map("messages")
}

model MessageRead {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  messageId String   @map("message_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  readAt    DateTime @default(now()) @map("read_at") @db.Timestamptz(6)
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@unique([messageId, userId])
  @@index([messageId])
  @@index([userId])
  @@map("message_reads")
}

model Review {
  id                    String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  engagementId          String     @map("engagement_id") @db.Uuid
  reviewerId            String     @map("reviewer_id") @db.Uuid
  targetId              String     @map("target_id") @db.Uuid
  rating                Int
  comment               String?
  structuredSignalsJson Json?      @map("structured_signals_json")
  reviewerRole          String     @map("reviewer_role")
  engagement            Engagement @relation(fields: [engagementId], references: [id])
  reviewer              User       @relation("ReviewsWritten", fields: [reviewerId], references: [id])
  target                User       @relation("ReviewsReceived", fields: [targetId], references: [id])

  @@unique([engagementId, reviewerId])
  @@index([engagementId])
  @@index([reviewerId])
  @@index([targetId])
  @@map("reviews")
}

model PlatformDecision {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  decisionType  String   @map("decision_type")
  entityType    String?  @map("entity_type")
  entityId      String?  @map("entity_id")
  llmConfidence Float?   @map("llm_confidence")
  decision      String?
  advisoryNote  String?  @map("advisory_note")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([decisionType])
  @@index([createdAt(sort: Desc)])
  @@index([entityType, entityId])
  @@map("platform_decisions")
}
