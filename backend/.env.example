# Database (Neon) 
DATABASE_URL=""
DIRECT_URL=""

# Auth
JWT_SECRET=REPLACE_WITH_64_BYTE_HEX
JWT_EXPIRES_IN=7d

# Platform 
PLATFORM_SETTINGS_ID=00000000-0000-0000-0000-000000000004
PLATFORM_FEE_PCT=0.05

# SePay
SEPAY_SECRET_KEY=REPLACE_LATER
SEPAY_API_BASE=https://my.sepay.vn/userapi

# Internal services 
# Local dev: http://localhost:8000
# Docker:    http://ai-service:8000        (set in docker-compose.yml, not here)
# Railway:   http://aitasker-ai.railway.internal:8000
FASTAPI_URL=http://localhost:8000

# CORS 
# Comma-separated list of allowed frontend origins.
# Local dev only needs localhost. Railway deployment needs Railway frontend URL(already done on Railway console)
CORS_ORIGIN=http://localhost:5173

# App
PORT=3001
NODE_ENV=development
